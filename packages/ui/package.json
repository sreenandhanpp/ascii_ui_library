    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@sreenandhanpp/ascii-ui-themes": "workspace:*",
    "@sreenandhanpp/ascii-ui-engine": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}